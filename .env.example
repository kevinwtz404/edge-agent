# core runtime
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_ACCOUNT_ID=default

# instruction source lock (Slack user IDs)
CRO_SLACK_USER_IDS=U12345678

# connector toggles
ENABLE_SLACK=true
ENABLE_EMAIL=true
ENABLE_CRM=true
ENABLE_SUPABASE=true

# optional data connectors
SUPABASE_URL=
SUPABASE_ANON_KEY=
CRM_PROVIDER=salesforce
CRM_BASE_URL=
CRM_ACCESS_TOKEN=

# model routing
DEFAULT_MODEL=anthropic
SENSITIVE_MODEL_ROUTING=local
OLLAMA_BASE_URL=http://127.0.0.1:11434

# logging
LOG_LEVEL=info
AUDIT_LOG_PATH=./logs/audit.log
