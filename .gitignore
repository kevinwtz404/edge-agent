# private/internal working files (never commit)
internal/
*.local.md
*.internal.md

# env and secrets
.env
.env.*
!.env.example

# local runtime artefacts
logs/
cache/
state/
node_modules/

# runtime policy copies (generated from examples)
config/policy/*.json
config/policy/*.yaml
!config/policy/*.example.json
!config/policy/*.example.yaml
